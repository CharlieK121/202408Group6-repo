<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title> SCHOLAR PATH | Profile Settings </title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css'>
    <link rel="stylesheet" href="../Styles/profileLandingStyle.css">
    <link rel="stylesheet" href="../Styles/navBar.css">

</head>

<body>
    <div id="header">
        <nav>
            <a href="/">Home</a>
            <a href="map">Map</a>
            <a href="profile">Profile</a>
            <a href="login">Login</a>
        </nav>
    </div>

    <section class="py-5 my-5">
        <div class="wrapper">
            <h1 class="mb-5"> My Profile </h1>
            <div class="bg-white shadow rounded-1g d-block d-sm-flex">
                <div class="profile-tab-nav border-right">
                    <div class="p-4">
                        <div class="img-circle text-center mb-3">
                            <img src="../Resources/Images/3.jpg" alt="Image" class="shadow">
                        </div>
                        <h4 class="text-center"><%= username %></h4>
                    </div>
                    <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                        <a class="nav-link active" id="account-tab" data-toggle="pill" href="#account" role="tab"
                            aria-controls="account" aria-selected="true">
                            <i class="fa fa-home text-center mr-1"></i>
                            Profile
                        </a>
                        <a class="nav-link" id="password-tab" data-toggle="pill" href="#password" role="tab"
                            aria-controls="password" aria-selected="false">
                            <i class="fa fa-key text-center mr-1"></i>
                            Password
                        </a>
                        <a class="nav-link" id="myFavorite-tab" data-toggle="pill" href="#myFavorite" role="tab"
                            aria-controls="myFavorite" aria-selected="false">
                            <i class="fa fa-tv text-center mr-1"></i>
                            My Favorite Classes
                        </a>
                        <a class="nav-link" id="myStudyGroup-tab" data-toggle="pill" href="#myStudyGroup" role="tab"
                            aria-controls="myStudyGroup" aria-selected="false">
                            <i class="fa fa-bell text-center mr-1"></i>
                            My Study Groups
                        </a>
                        <a class="nav-link" id="myEvents-tab" data-toggle="pill" href="#myEvents" role="tab"
                            aria-controls="myEvents" aria-selected="false">
                            <i class="fa fa-ser text-center mr-1"></i>
                            My Events
                        </a>
                        <a class="nav-link" id="mySecurity-tab" data-toggle="pill" href="#mySecurity" role="tab"
                            aria-controls="mySecurity" aria-selected="false">
                            <i class="fa fa-ser text-center mr-1"></i>
                            Security
                        </a>
                    </div>
                </div>
                <div class="tab-content p-4 md-5" id="v-pills-tabContent">
                    <div class="tab-pane fade show active" id="account" role="tabpanel" aria-labelledby="account-tab">
                        <h3 class="mb-4"> Profile Settings </h3>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label> First Name </label>
                                    <input type="text" class="form-control" value="Jane">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label> Last Name </label>
                                    <input type="text" class="form-control" value="Doe">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label> Email </label>
                                    <input type="text" class="form-control" value="fakeusername@calstatela.edu">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label> Phone Number </label>
                                    <input type="text" class="form-control" value="213-456-7891">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label> Joined </label>
                                    <label class="form-control">11/07/2024</label>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label> Bio </label>
                                    <textarea class="form-control" rows="4">Hello I am on ScholarPath</textarea>
                                </div>
                            </div>
                        </div>
                        <div>
                            <button class="btn btn-primary"> Update </button>
                            <button class="btn btn-light"> Cancel </button>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="myFavorite" role="tabpanel" aria-labelledby="myFavorite-tab">
                        <h3 class="mb-4"> My Favorites </h3>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" value="" id="app-check">
                                        <label class="form-check-label" for="app-check">
                                            Attending?
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" value="" id="defaultCheck">
                                        <label class="form-check-label" for="defaultCheck">
                                            Scholar Path saved my life!
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div>
                            <button class="btn btn-primary"> Update </button>
                            <button class="btn btn-light"> Cancel </button>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="myEvents" role="tabpanel" aria-labelledby="myEvents-tab">
                        <h3 class="mb-4"> My Events </h3>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" value="" id="app-check1">
                                        <label class="form-check-label" for="app-check1">
                                            Sign up?
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" value="" id="defaultCheck2">
                                        <label class="form-check-label" for="defaultCheck2">
                                            Attending!
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div>
                            <button class="btn btn-primary"> Update </button>
                            <button class="btn btn-light"> Cancel </button>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="myStudyGroup" role="tabpanel" aria-labelledby="myStudyGroup-tab">
                        <h3 class="mb-4"> My Study Groups </h3>
                        <div class="form-group">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="notification1">
                                <label class="form-check-label" for="notification1">
                                    Attending?
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="notification2">
                                <label class="form-check-label" for="notification2">
                                    I love study groups
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="notification3">
                                <label class="form-check-label" for="notification3">
                                    Can we be the study group from community?
                                </label>
                            </div>
                        </div>
                        <div>
                            <button class="btn btn-primary"> Update </button>
                            <button class="btn btn-light"> Cancel </button>
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="password" role="tabpanel" aria-labelledby="password-tab">
                    <h3 class="mb-4"> Password Settings </h3>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label> Old Password </label>
                                <input type="password" class="form-control">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label> New Password </label>
                                <input type="password" class="form-control">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label> Confirm New Passowrd </label>
                                <input type="password" class="form-control">
                            </div>
                        </div>
                    </div>
                    <div>
                        <button class="btn btn-primary"> Update </button>
                        <button class="btn btn-light"> Cancel </button>
                    </div>
                </div>
                <div class="tab-pane fade" id="mySecurity" role="tabpanel" aria-labelledby="mySecurity-tab">
                    <h3 class="mb-4"> Security Settings </h3>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label> Login </label>
                                <input type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label> Two-Factor Authentication </label>
                                <input type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="recovery">
                                    <label class="form-check-label" for="recovery">
                                        Recovery
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div>
                        <button class="btn btn-primary"> Update </button>
                        <button class="btn btn-light"> Cancel </button>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <script src="../Scripts/profileLanding.js"></script>
  
</body>

</html>