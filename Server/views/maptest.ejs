<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="../Styles/navbar.css" nonce="<%= nonce %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous" nonce="<%= nonce %>">
    
    <!-- Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" nonce="<%= nonce %>"/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" nonce="<%= nonce %>"></script>
    
    <!-- Leaflet Routing Machine -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.2.0/dist/leaflet.css" nonce="<%= nonce %>"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.css" nonce="<%= nonce %>"/>
    <script src="https://unpkg.com/leaflet@1.2.0/dist/leaflet.js" nonce="<%= nonce %>"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.js" nonce="<%= nonce %>"></script>

    <!-- GraphHopper Routing (Pedestrian) -->
    <!-- <script src="../Resources/Credentials/GraphHopperKey.js" nonce="<%= nonce %>"></script> -->
    
    <script src="../Scripts/L.Routing.GraphHopper.js" nonce="<%= nonce %>"></script>

    <link rel="stylesheet" href="../Styles/leaflet-mod.css"nonce="<%= nonce %>">

    <!-- DB CLASSES -->
    <script type="module" src="../DBClasses/Front/FBuilding.js" nonce="<%= nonce %>"></script>
    <script type="module" src="../DBClasses/Front/FClass.js" nonce="<%= nonce %>"></script>
    <script type="module" src="../DBClasses/Front/FUser.js" nonce="<%= nonce %>"></script>
     
    <link rel="stylesheet" href="../Styles/map.css" nonce="<%= nonce %>">
    <link rel="stylesheet" href="../Styles/dropdown.css" nonce="<%= nonce %>">
    <link rel="stylesheet" href="../Styles/searchbar.css" nonce="<%= nonce %>">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scholar Path</title>
</head>
<body>
    <div id='page-container'>
        <div id="header">
            <nav>
                <a href="/">Scholar Path</a>
                <a href="/">Home</a>
                <a href="profile">Profile</a>
                <a href="logout">Logout</a>
            </nav>
        </div>

        <div class="dd-container">
            <div class="dd">
              <div class="dd-header" id="classes-header">My Classes</div>
              <ul class="list-group" id="selection"></ul>
            </div>
            <!-- Add more dropdowns here -->
        </div>

        <div class="search-container">
            <input type="text" id="search" class="search-bar" placeholder="Searching for something on campus?">
            <button id="clear-search" class="clear-btn" aria-label="Clear Search" onclick="clearSearch()">X</button>
            <ul id="search-results" class="dd"></ul>
        </div>
    
        <div id="map"></div>

        <!-- Coordinate display in the bottom-left corner -->
        <div id="coordinates">
            <h3>Coordinates</h3>
            <p id="lat">Latitude: </p>
            <p id="lng">Longitude: </p>
        </div>
        
        <button id="center-user"></button>
        
        <script type="module" src="../Scripts/map.js" nonce="<%= nonce %>"></script>
        <script src="../Scripts/Amenity.js" nonce="<%= nonce %>"></script>
    </div>
</body>
</html>